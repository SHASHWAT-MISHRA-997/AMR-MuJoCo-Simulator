<?xml version="1.0"?>
<robot name="mobile_manipulator_amr">
  <material name="aluminum_mat">
    <color rgba="0.83 0.85 0.87 1.0"/>
  </material>
  <material name="dark_panel_mat">
    <color rgba="0.16 0.18 0.20 1.0"/>
  </material>
  <material name="sensor_dark">
    <color rgba="0.12 0.14 0.16 1.0"/>
  </material>
  <material name="wheel_dark">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>
  <material name="arm_white">
    <color rgba="0.91 0.93 0.95 1.0"/>
  </material>
  <material name="safety_orange">
    <color rgba="0.96 0.64 0.12 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <geometry>
        <box size="0.90 0.56 0.05"/>
      </geometry>
      <material name="dark_panel_mat"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.45" rpy="0 0 0"/>
      <geometry>
        <box size="0.88 0.56 0.05"/>
      </geometry>
      <material name="dark_panel_mat"/>
    </visual>
    <visual>
      <origin xyz="0.43 0 0.23" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.60 0.36"/>
      </geometry>
      <material name="aluminum_mat"/>
    </visual>
    <visual>
      <origin xyz="-0.43 0 0.20" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.58 0.32"/>
      </geometry>
      <material name="dark_panel_mat"/>
    </visual>

    <visual><origin xyz="0.12 0.24 0.16" rpy="0 0 0"/><geometry><box size="0.68 0.04 0.04"/></geometry><material name="aluminum_mat"/></visual>
    <visual><origin xyz="0.12 -0.24 0.16" rpy="0 0 0"/><geometry><box size="0.68 0.04 0.04"/></geometry><material name="aluminum_mat"/></visual>
    <visual><origin xyz="0.02 0.24 0.30" rpy="0 0 0"/><geometry><box size="0.76 0.04 0.04"/></geometry><material name="aluminum_mat"/></visual>
    <visual><origin xyz="0.02 -0.24 0.30" rpy="0 0 0"/><geometry><box size="0.76 0.04 0.04"/></geometry><material name="aluminum_mat"/></visual>
    <visual><origin xyz="0.02 0.24 0.44" rpy="0 0 0"/><geometry><box size="0.76 0.04 0.04"/></geometry><material name="aluminum_mat"/></visual>
    <visual><origin xyz="0.02 -0.24 0.44" rpy="0 0 0"/><geometry><box size="0.76 0.04 0.04"/></geometry><material name="aluminum_mat"/></visual>
    <visual><origin xyz="0.26 0 0.44" rpy="0 0 0"/><geometry><box size="0.04 0.48 0.04"/></geometry><material name="aluminum_mat"/></visual>
    <visual><origin xyz="0.00 0 0.44" rpy="0 0 0"/><geometry><box size="0.04 0.48 0.04"/></geometry><material name="aluminum_mat"/></visual>
    <visual><origin xyz="-0.26 0 0.44" rpy="0 0 0"/><geometry><box size="0.04 0.48 0.04"/></geometry><material name="aluminum_mat"/></visual>

    <visual><origin xyz="0.30 0.24 0.30" rpy="0 0 0"/><geometry><box size="0.04 0.04 0.32"/></geometry><material name="aluminum_mat"/></visual>
    <visual><origin xyz="0.30 -0.24 0.30" rpy="0 0 0"/><geometry><box size="0.04 0.04 0.32"/></geometry><material name="aluminum_mat"/></visual>
    <visual><origin xyz="-0.30 0.24 0.30" rpy="0 0 0"/><geometry><box size="0.04 0.04 0.32"/></geometry><material name="aluminum_mat"/></visual>
    <visual><origin xyz="-0.30 -0.24 0.30" rpy="0 0 0"/><geometry><box size="0.04 0.04 0.32"/></geometry><material name="aluminum_mat"/></visual>

    <visual>
      <origin xyz="0 0 0.18" rpy="0 0 0"/>
      <geometry>
        <box size="0.32 0.32 0.22"/>
      </geometry>
      <material name="dark_panel_mat"/>
    </visual>
    <visual>
      <origin xyz="-0.12 0 0.28" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.20 0.16"/>
      </geometry>
      <material name="dark_panel_mat"/>
    </visual>
    <visual>
      <origin xyz="0.20 0 0.72" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.06 0.44"/>
      </geometry>
      <material name="aluminum_mat"/>
    </visual>
    <visual>
      <origin xyz="0.20 0 0.90" rpy="0 0 0"/>
      <geometry>
        <box size="0.20 0.05 0.04"/>
      </geometry>
      <material name="aluminum_mat"/>
    </visual>
    <visual>
      <origin xyz="0.30 0 0.88" rpy="0 0 0"/>
      <geometry>
        <box size="0.18 0.10 0.08"/>
      </geometry>
      <material name="sensor_dark"/>
    </visual>
    <visual>
      <origin xyz="0.45 0 0.10" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.46 0.12"/>
      </geometry>
      <material name="safety_orange"/>
    </visual>
  </link>

  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.085" length="0.07"/>
      </geometry>
      <material name="wheel_dark"/>
    </visual>
  </link>

  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.085" length="0.07"/>
      </geometry>
      <material name="wheel_dark"/>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 0.26 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0 -0.26 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="laser_frame"/>
  <joint name="laser_frame_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 0.42" rpy="0 0 0"/>
  </joint>

  <link name="front_left_lidar_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.036" length="0.056"/>
      </geometry>
      <material name="sensor_dark"/>
    </visual>
  </link>

  <joint name="front_left_lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_lidar_frame"/>
    <origin xyz="0.34 0.24 0.42" rpy="0 0 0.78539816339"/>
  </joint>

  <link name="rear_right_lidar_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.036" length="0.056"/>
      </geometry>
      <material name="sensor_dark"/>
    </visual>
  </link>

  <joint name="rear_right_lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_right_lidar_frame"/>
    <origin xyz="-0.28 -0.24 0.42" rpy="0 0 3.92699081699"/>
  </joint>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.30" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.18 0.10 0.08"/>
      </geometry>
      <material name="sensor_dark"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.30 0 0.88" rpy="0 0 0"/>
  </joint>

  <link name="camera_rgb_optical_frame"/>
  <joint name="camera_rgb_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_rgb_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <link name="camera_depth_optical_frame"/>
  <joint name="camera_depth_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <link name="arm_base_link">
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><cylinder radius="0.07" length="0.16"/></geometry>
      <material name="dark_panel_mat"/>
    </visual>
  </link>
  <joint name="arm_base_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="-0.04 0 0.48" rpy="0 0 0"/>
  </joint>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0.04 0 0.08" rpy="0 1.57079632679 0"/>
      <geometry><cylinder radius="0.06" length="0.24"/></geometry>
      <material name="arm_white"/>
    </visual>
  </link>
  <joint name="arm_base_joint" type="revolute">
    <parent link="arm_base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="20" velocity="1.5"/>
  </joint>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0.18 0 0" rpy="0 1.57079632679 0"/>
      <geometry><cylinder radius="0.04" length="0.36"/></geometry>
      <material name="arm_white"/>
    </visual>
  </link>
  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0.08 0 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="1.4" effort="20" velocity="1.5"/>
  </joint>

  <link name="elbow_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.055"/></geometry>
      <material name="dark_panel_mat"/>
    </visual>
  </link>
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="elbow_link"/>
    <origin xyz="0.36 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.2" upper="2.2" effort="20" velocity="1.6"/>
  </joint>

  <link name="forearm_link">
    <visual>
      <origin xyz="0.16 0 0" rpy="0 1.57079632679 0"/>
      <geometry><cylinder radius="0.032" length="0.32"/></geometry>
      <material name="arm_white"/>
    </visual>
  </link>
  <joint name="forearm_mount_joint" type="fixed">
    <parent link="elbow_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.04 0 0" rpy="0 0 0"/>
  </joint>

  <link name="wrist_pitch_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.045"/></geometry>
      <material name="sensor_dark"/>
    </visual>
  </link>
  <joint name="wrist_pitch_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_pitch_link"/>
    <origin xyz="0.32 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="12" velocity="1.8"/>
  </joint>

  <link name="wrist_roll_link">
    <visual>
      <origin xyz="0.07 0 0" rpy="0 1.57079632679 0"/>
      <geometry><cylinder radius="0.025" length="0.14"/></geometry>
      <material name="arm_white"/>
    </visual>
  </link>
  <joint name="wrist_roll_joint" type="revolute">
    <parent link="wrist_pitch_link"/>
    <child link="wrist_roll_link"/>
    <origin xyz="0.06 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2.0"/>
  </joint>

  <link name="gripper_link">
    <visual>
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.06 0.06"/></geometry>
      <material name="dark_panel_mat"/>
    </visual>
    <visual>
      <origin xyz="0.12 0.035 0" rpy="0 0 0"/>
      <geometry><box size="0.10 0.016 0.024"/></geometry>
      <material name="aluminum_mat"/>
    </visual>
    <visual>
      <origin xyz="0.12 -0.035 0" rpy="0 0 0"/>
      <geometry><box size="0.10 0.016 0.024"/></geometry>
      <material name="aluminum_mat"/>
    </visual>
  </link>
  <joint name="gripper_joint" type="fixed">
    <parent link="wrist_roll_link"/>
    <child link="gripper_link"/>
    <origin xyz="0.14 0 0" rpy="0 0 0"/>
  </joint>

  <link name="tool0"/>
  <joint name="tool0_joint" type="fixed">
    <parent link="gripper_link"/>
    <child link="tool0"/>
    <origin xyz="0.16 0 0" rpy="0 0 0"/>
  </joint>
</robot>
